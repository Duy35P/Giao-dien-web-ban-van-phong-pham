@model List<ĐỒ_ÁN.tblSanPham>

@{
    ViewBag.Title = "Trang chủ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- CSS TÙY CHỈNH CHO TRANG CHỦ -->
<style>
    /* --- 1. PROMO CARDS (CŨ - GIỮ NGUYÊN) --- */
    .promo-card {
        position: relative;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        transition: transform 0.3s;
        height: 200px; /* Cố định chiều cao cho đều */
    }

        .promo-card:hover {
            transform: translateY(-5px);
        }

        .promo-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .promo-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
        padding: 15px;
        color: white;
    }

    /* --- 2. BANNER QUẢNG CÁO MỚI (NEW) --- */
    .promo-section-title {
        border-left: 5px solid #1a94ff;
        padding-left: 10px;
        margin-bottom: 20px;
        font-weight: bold;
        color: #333;
        text-transform: uppercase;
    }

    /* Lưới quảng cáo đa dạng */
    .ad-grid-large {
        display: grid;
        grid-template-columns: 2fr 1fr; /* Cột trái to gấp đôi cột phải */
        gap: 15px;
        margin-bottom: 15px;
    }

    .ad-grid-small {
        display: grid;
        grid-template-columns: repeat(4, 1fr); /* 4 cột đều nhau */
        gap: 15px;
    }

    .ad-item {
        border-radius: 8px;
        overflow: hidden;
        position: relative;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }

        .ad-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 0.5s;
        }

        .ad-item:hover img {
            transform: scale(1.02);
        }

    /* Khung giữ chỗ cho hình chưa có (Placeholder) */
    .img-placeholder {
        background-color: #e9ecef;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #6c757d;
        font-weight: bold;
        text-align: center;
        border: 2px dashed #ced4da;
    }

    /* --- 3. PRODUCT CARD (THIẾT KẾ MỚI ĐẸP HƠN) --- */
    .product-card-new {
        background: white;
        border: 1px solid #f0f0f0;
        border-radius: 8px;
        padding: 10px;
        transition: all 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        position: relative;
    }

        .product-card-new:hover {
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
            border-color: #1a94ff;
            transform: translateY(-2px);
        }

    .prod-img-wrap {
        height: 180px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 10px;
        overflow: hidden;
    }

        .prod-img-wrap img {
            max-height: 100%;
            max-width: 100%;
            object-fit: contain;
            transition: 0.3s;
        }

    .product-card-new:hover .prod-img-wrap img {
        transform: scale(1.05);
    }

    .prod-title a {
        font-size: 14px;
        font-weight: 500;
        color: #333;
        text-decoration: none;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        height: 40px;
        margin-bottom: 5px;
        line-height: 1.4;
    }

        .prod-title a:hover {
            color: #1a94ff;
        }

    .prod-price {
        font-size: 16px;
        font-weight: bold;
        color: #d0021b; /* Đỏ giá tiền */
        margin-bottom: 10px;
    }

    .btn-add-cart-blue {
        background-color: white;
        color: #1a94ff;
        border: 1px solid #1a94ff;
        width: 100%;
        padding: 6px;
        border-radius: 4px;
        font-size: 13px;
        font-weight: 600;
        margin-top: auto;
        transition: 0.2s;
    }

        .btn-add-cart-blue:hover {
            background-color: #1a94ff;
            color: white;
        }

    .card-badge {
        position: absolute;
        top: 8px;
        right: 8px;
        background: #ff424e;
        color: white;
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 10px;
        font-weight: bold;
        z-index: 2;
    }
</style>

<!-- 1. CAROUSEL CHÍNH (GIỮ NGUYÊN) -->
<div id="mainBanner" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#mainBanner" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#mainBanner" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#mainBanner" data-bs-slide-to="2"></button>
    </div>
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="~/Content/Images/QuangCao.jpg" class="d-block w-100" style="height: 400px; object-fit: cover;" alt="Banner 1" onerror="this.src='https://via.placeholder.com/1200x400?text=Banner+Quang+Cao+1'">
        </div>
        <div class="carousel-item">
            <img src="~/Content/Images/QuangCao2.jpg" class="d-block w-100" style="height: 400px; object-fit: cover;" alt="Banner 2" onerror="this.src='https://via.placeholder.com/1200x400?text=Banner+Quang+Cao+2'">
        </div>
        <div class="carousel-item">
            <img src="~/Content/Images/QuangCao3.jpg" class="d-block w-100" style="height: 400px; object-fit: cover;" alt="Banner 3" onerror="this.src='https://via.placeholder.com/1200x400?text=Banner+Quang+Cao+3'">
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#mainBanner" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#mainBanner" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

<!-- 2. BANNER QUẢNG CÁO MỚI (THÊM VÀO - CHỜ BẠN CHÈN HÌNH) -->
<div class="container-fluid px-4 mt-4">
    <h4 class="promo-section-title">Ưu đãi & Sự kiện</h4>

    <!-- Hàng 1: 1 Hình lớn + 1 Hình vừa -->
    <div class="ad-grid-large">
        <div class="ad-item">
            <!-- Ô TRỐNG 1: Banner Ngang Lớn (Vd: Outlet, Sale lớn) -->
            <a href="#">
                <img src="~/Content/Images/Quangcao4.jpg" class="img-placeholder" style="height: 250px;" alt="Banner Lớn (Bạn tự thêm hình)" onerror="this.src='https://via.placeholder.com/800x250?text=Banner+Lon+(Outlet/Sale)'">
            </a>
        </div>
        <div class="ad-item">
            <!-- Ô TRỐNG 2: Banner Vừa -->
            <a href="#">
                <img src="~/Content/Images/Quangcao5.jpg" class="img-placeholder" style="height: 250px;" alt="Banner Vừa" onerror="this.src='https://via.placeholder.com/400x250?text=Banner+Deal+Xin'">
            </a>
        </div>
    </div>

    <!-- Hàng 2: 4 Hình nhỏ -->
    <div class="ad-grid-small">
        <div class="ad-item">
            <a href="#">
                <img src="~/Content/Images/Quangcao6.jpg" class="img-placeholder" style="height: 150px;" alt="QC Nhỏ 1" onerror="this.src='https://via.placeholder.com/300x150?text=Quang+Cao+1'">
            </a>
        </div>
        <div class="ad-item">
            <a href="#">
                <img src="~/Content/Images/Quangcao7.jpg" class="img-placeholder" style="height: 150px;" alt="QC Nhỏ 2" onerror="this.src='https://via.placeholder.com/300x150?text=Quang+Cao+2'">
            </a>
        </div>
        <div class="ad-item">
            <a href="#">
                <img src="~/Content/Images/Quangcao8.jpg" class="img-placeholder" style="height: 150px;" alt="QC Nhỏ 3" onerror="this.src='https://via.placeholder.com/300x150?text=Quang+Cao+3'">
            </a>
        </div>
        <div class="ad-item">
            <a href="#">
                <img src="~/Content/Images/Quangcao9.jpg" class="img-placeholder" style="height: 150px;" alt="QC Nhỏ 4" onerror="this.src='https://via.placeholder.com/300x150?text=Quang+Cao+4'">
            </a>
        </div>
    </div>
</div>

<!-- 3. BANNER BOXES  -->
<div class="container-fluid px-4 my-4">
    <div class="row g-3">
        <div class="col-md-4">
            <div class="promo-card">
                <img src="~/Content/Images/ButBi.jpg" alt="Bút bi" onerror="this.src='https://via.placeholder.com/400x200?text=Giam+Gia+But+Bi'">
                <div class="promo-overlay"><h3>Giảm giá 30% cho bút bi</h3></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="promo-card">
                <img src="~/Content/Images/TapVo.jpg" alt="Tập vở" onerror="this.src='https://via.placeholder.com/400x200?text=Tap+Vo+Cao+Cap'">
                <div class="promo-overlay"><h3>Tập vở cao cấp nhập khẩu</h3></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="promo-card">
                <img src="~/Content/Images/Combo.jpg" alt="Combo" onerror="this.src='https://via.placeholder.com/400x200?text=Combo+Sieu+Re'">
                <div class="promo-overlay"><h3>Combo dụng cụ học tập siêu rẻ</h3></div>
            </div>
        </div>
    </div>
</div>

<!-- 4. DANH SÁCH SẢN PHẨM  -->
<div class="container-fluid px-4 my-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary fw-bold m-0" style="border-left: 5px solid #1a94ff; padding-left: 10px;">SẢN PHẨM NỔI BẬT</h2>
        
    </div>

    <!-- Tăng số cột lên 5 để hiển thị được nhiều sản phẩm hơn -->
    <div class="row g-3 row-cols-2 row-cols-md-4 row-cols-lg-5">
        @if (Model != null && Model.Any())
        {
           
            foreach (var item in Model.Take(10))
            {
                <div class="col">
                    <div class="product-card-new">
                        <!-- Badge mới (Giả lập) -->
                        <span class="card-badge">Mới</span>

                        <div class="prod-img-wrap">
                            <a href="@Url.Action("ChiTietSanPham", "Home", new { id = item.MaSP })">
                                <img src="@Url.Content("~/Content/Images/" + item.AnhDaiDien)"
                                     alt="@item.TenSP"
                                     onerror="this.src='https://via.placeholder.com/300x300?text=No+Image'">
                            </a>
                        </div>

                        <div class="prod-title">
                            <a href="@Url.Action("ChiTietSanPham", "Home", new { id = item.MaSP })" title="@item.TenSP">
                                @item.TenSP
                            </a>
                        </div>



                        <div class="prod-rating">
                            <i class="fas fa-star text-warning"></i>
                            <i class="fas fa-star text-warning"></i>
                            <i class="fas fa-star text-warning"></i>
                            <i class="fas fa-star text-warning"></i>
                            <i class="fas fa-star text-warning"></i>
                            <span class="text-muted small">(52)</span>
                        </div>

                        <div class="prod-price">
                            @item.GiaBan.Value.ToString("N0")₫
                        </div>

                        <a href="@Url.Action("ChiTietSanPham", "Home", new { id = item.MaSP })" class="btn btn-outline-primary btn-sm w-100">
                            <i class="bi bi-eye-fill"></i> Xem chi tiết
                        </a>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info text-center py-5" role="alert">
                    <i class="fas fa-info-circle fa-2x mb-3"></i><br>
                    Hiện tại chưa có sản phẩm nào
                </div>
            </div>
        }
    </div>

    <!-- Nút xem thêm ở cuối -->
    <div class="text-center mt-5">
        <a href="@Url.Action("SP", "Home")" class="btn btn-outline-primary px-5 py-2 rounded-pill fw-bold">
            Xem thêm sản phẩm khác
        </a>
    </div>
</div>