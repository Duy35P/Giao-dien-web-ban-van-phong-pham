@model IEnumerable<ĐỒ_ÁN.tblNhanVien>
@{
    ViewBag.Title = "Quản Lý Nhân Viên";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-person-badge"></i> Quản Lý Nhân Viên</h2>
        <a href="@Url.Action("ThemNhanVien","Admin")" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Thêm Nhân Viên Mới
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <table class="table table-hover table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Mã NV</th>
                        <th>Tên Nhân Viên</th>
                        <th>Giới Tính</th>
                        <th>Năm Sinh</th>
                        <th>Vai Trò</th>
                        <th>Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.MaNV</td>
                            <td>
                                <strong>@item.TenNV</strong>
                                @if (item.MaNV == (int)Session["NVId"])
                                {
                                    <span class="badge bg-info">Bạn</span>
                                }
                            </td>
                            <td>@item.GioiTinh</td>
                            <td>@item.NamSinh</td>
                            <td>
                                @if (item.VaiTro == 1)
                                {
                                    <span class="badge bg-danger">@item.tblVaiTro.TenVaiTro</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.tblVaiTro.TenVaiTro</span>
                                }
                            </td>
                            <td>
                                <a href="@Url.Action("ChiTietNhanVien","Admin", new { id = item.MaNV })"
                                   class="btn btn-sm btn-info" title="Chi tiết">
                                    <i class="bi bi-eye">Xem</i>
                                </a>
                                <a href="@Url.Action("SuaNhanVien","Admin", new { id = item.MaNV })"
                                   class="btn btn-sm btn-warning" title="Sửa">
                                    <i class="bi bi-pencil-square">Sửa</i>
                                </a>
                                @if (item.MaNV != (int)Session["NVId"])
                                {
                                    <button type="button" class="btn btn-sm btn-danger"
                                            onclick="xoaNhanVien(@item.MaNV)" title="Xóa">
                                        <i class="bi bi-trash">Xóa</i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section scripts {
    <script>
        function xoaNhanVien(id) {
            if (confirm('Bạn có chắc chắn muốn xóa nhân viên này?')) {
                $.ajax({
                    url: '@Url.Action("XoaNhanVien", "Admin")',
                    type: 'POST',
                    data: { id: id },
                    success: function () {
                        location.reload();
                    }
                });
            }
        }
    </script>
}