@model ĐỒ_ÁN.tblHoaDon
@{
    ViewBag.Title = "Chi Tiết Đơn Hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var chiTiet = (List<ĐỒ_ÁN.tblChiTietHoaDon>)ViewBag.ChiTiet;
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-receipt"></i> Chi Tiết Đơn Hàng #@Model.MaHD</h2>
        <a href="@Url.Action("QuanLyDonHang","Admin")" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header bg-primary text-white">
                    <h5><i class="bi bi-person"></i> Thông Tin Khách Hàng</h5>
                </div>
                <div class="card-body">
                    <p><strong>Tên:</strong> @Model.tblKhachHang.TenKH</p>
                    <p><strong>Email:</strong> @Model.tblKhachHang.Email</p>
                    <p><strong>Điện thoại:</strong> @Model.tblKhachHang.DienThoai</p>
                    <p><strong>Địa chỉ giao hàng:</strong> @Model.DiaChiGiaoHang</p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header bg-success text-white">
                    <h5><i class="bi bi-info-circle"></i> Thông Tin Đơn Hàng</h5>
                </div>
                <div class="card-body">
                    <p><strong>Ngày lập:</strong> @Model.NgayLap.Value.ToString("dd/MM/yyyy HH:mm")</p>
                    <p><strong>Nhân viên xử lý:</strong> @(Model.tblNhanVien != null ? Model.tblNhanVien.TenNV : "Chưa xử lý")</p>
                    <p><strong>Tổng tiền:</strong> <span class="text-danger fs-5">@string.Format("{0:N0}đ", Model.TongTien)</span></p>
                    <p>
                        <strong>Thanh toán:</strong>
                        @if (Model.DaThanhToan == true)
                        {
                            <span class="badge bg-success">Đã thanh toán</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">Chưa thanh toán</span>
                        }
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header bg-warning">
            <h5><i class="bi bi-box-seam"></i> Chi Tiết Sản Phẩm</h5>
        </div>
        <div class="card-body">
            <table class="table table-bordered">
                <thead class="table-dark">
                    <tr>
                        <th>STT</th>
                        <th>Tên Sản Phẩm</th>
                        <th>Đơn Giá</th>
                        <th>Số Lượng</th>
                        <th>Thành Tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int stt = 1;
                    }
                    @foreach (var item in chiTiet)
                    {
                        <tr>
                            <td>@stt</td>
                            <td>@item.tblSanPham.TenSP</td>
                            <td>@string.Format("{0:N0}đ", item.GiaBan)</td>
                            <td>@item.SoLuong</td>
                            <td>@string.Format("{0:N0}đ", item.GiaBan * item.SoLuong)</td>
                        </tr>
                        stt++;
                    }
                </tbody>
                <tfoot>
                    <tr class="table-active">
                        <td colspan="4" class="text-end"><strong>Tổng Cộng:</strong></td>
                        <td><strong class="text-danger">@string.Format("{0:N0}đ", Model.TongTien)</strong></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-info text-white">
            <h5><i class="bi bi-pencil-square"></i> Cập Nhật Đơn Hàng</h5>
        </div>
        <div class="card-body">
            @using (Html.BeginForm("CapNhatDonHang", "Admin", FormMethod.Post))
            {
                @Html.Hidden("MaHD", Model.MaHD)
                
                <div class="row">
                    <div class="col-md-6">
                        <label class="form-label"><strong>Tình trạng đơn hàng:</strong></label>
                        @Html.DropDownList("TinhTrang", (SelectList)ViewBag.TinhTrangs, new { @class = "form-select mb-3" })
                    </div>

                    <div class="col-md-6">
                        <label class="form-label"><strong>Trạng thái thanh toán:</strong></label>
                        <select name="DaThanhToan" class="form-select mb-3">
                            <option value="false" @(Model.DaThanhToan == false ? "selected" : "")>Chưa thanh toán</option>
                            <option value="true" @(Model.DaThanhToan == true ? "selected" : "")>Đã thanh toán</option>
                        </select>
                    </div>
                </div>

                <div class="text-center">
                    <button type="submit" class="btn btn-primary btn-lg px-5">
                        <i class="bi bi-save"></i> Cập Nhật Đơn Hàng
                    </button>
                </div>
            }
        </div>
    </div>
</div>