@model ĐỒ_ÁN.tblNhanVien
@{
    ViewBag.Title = "Chi Tiết Nhân Viên";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var donHang = (List<ĐỒ_ÁN.tblHoaDon>)ViewBag.DonHangXuLy;
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-person-circle"></i> Chi Tiết Nhân Viên</h2>
        <a href="@Url.Action("QuanLyNhanVien","Admin")" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <div class="rounded-circle bg-primary d-inline-flex align-items-center justify-content-center mb-3"
                         style="width: 150px; height: 150px;">
                        <i class="bi bi-person-fill text-white" style="font-size: 80px;"></i>
                    </div>

                    <h4>@Model.TenNV</h4>
                    <p class="text-muted">Mã NV: #@Model.MaNV</p>
                    <p>
                        @if (Model.VaiTro == 1)
                        {
                            <span class="badge bg-danger">@Model.tblVaiTro.TenVaiTro</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@Model.tblVaiTro.TenVaiTro</span>
                        }
                    </p>

                    <hr />

                    <div class="row text-center">
                        <div class="col-6">
                            <h5 class="text-primary">@ViewBag.TongDonHang</h5>
                            <small class="text-muted">Đơn xử lý</small>
                        </div>
                        <div class="col-6">
                            <h5 class="text-success">@string.Format("{0:N0}đ", ViewBag.TongDoanhThu)</h5>
                            <small class="text-muted">Doanh thu</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card mb-3">
                <div class="card-header bg-primary text-white">
                    <h5><i class="bi bi-info-circle"></i> Thông Tin Cá Nhân</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-2">
                        <div class="col-4"><strong>Tên đăng nhập:</strong></div>
                        <div class="col-8">@Model.TenNV</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-4"><strong>Giới tính:</strong></div>
                        <div class="col-8">@Model.GioiTinh</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-4"><strong>Năm sinh:</strong></div>
                        <div class="col-8">@Model.NamSinh</div>
                    </div>
                    <div class="row">
                        <div class="col-4"><strong>Vai trò:</strong></div>
                        <div class="col-8">@Model.tblVaiTro.TenVaiTro - @Model.tblVaiTro.MoTa</div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5><i class="bi bi-clipboard-check"></i> Đơn Hàng Đã Xử Lý</h5>
                </div>
                <div class="card-body">
                    @if (donHang != null && donHang.Count > 0)
                    {
                        <table class="table table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Mã ĐH</th>
                                    <th>Khách Hàng</th>
                                    <th>Ngày Lập</th>
                                    <th>Tổng Tiền</th>
                                    <th>Tình Trạng</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var hd in donHang.Take(10))
                                {
                                    <tr>
                                        <td>
                                            <a href="@Url.Action("ChiTietDonHang","Admin", new { id = hd.MaHD })">
                                                #@hd.MaHD
                                            </a>
                                        </td>
                                        <td>@hd.tblKhachHang.TenKH</td>
                                        <td>@hd.NgayLap.Value.ToString("dd/MM/yyyy")</td>
                                        <td>@string.Format("{0:N0}đ", hd.TongTien)</td>
                                        <td>
                                            @{
                                                var badgeClass = "";
                                                switch (hd.TinhTrang)
                                                {
                                                    case 1: badgeClass = "bg-warning"; break;
                                                    case 2: badgeClass = "bg-info"; break;
                                                    case 3: badgeClass = "bg-success"; break;
                                                    case 4: badgeClass = "bg-danger"; break;
                                                }
                                            }
                                            <span class="badge @badgeClass">@hd.tblTinhTrang.TinhTrangHoaDon</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        if (donHang.Count > 10)
                        {
                            <p class="text-center text-muted">Hiển thị 10/@donHang.Count đơn hàng gần nhất</p>
                        }
                    }
                    else
                    {
                        <p class="text-center text-muted">Chưa xử lý đơn hàng nào</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>